{
  "name": "boardrunner",
  "version": "3.1.4",
  "description": "BoardRunner - enterprise wallboard display management for rotating live dashboards across multiple screens",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "Nathan Ersser"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "publish:github": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.extech.boardrunner",
    "productName": "BoardRunner",
    "copyright": "Copyright \u00a9 2026 Nathan Ersser",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "admin.html",
      "admin.css",
      "admin.js",
      "config.json",
      "assets/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BoardRunner",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nate-et",
        "repo": "BoardRunner"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nate-et/BoardRunner.git"
  }
}